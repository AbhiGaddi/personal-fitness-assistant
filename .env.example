# Database Connection Details (PostgreSQL example)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

# AWS S3 Configuration
S3_BUCKET_NAME=your-s3-backup-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# It's recommended to use IAM roles/profiles if running on EC2/ECS/Lambda for better security
# and avoid hardcoding AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY directly.
